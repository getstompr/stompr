{
    "name": "travel-ai-platform",
    "version": "0.1.0",
    "description": "High-end travel AI platform MVP (shared control plane + tenant pods)",
    "type": "module",
    "main": "dist/server.js",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc -p tsconfig.json",
        "start": "node dist/server.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "db:migrate": "tsx src/db/migrate.ts",
        "qa:pilot": "tsx scripts/pilot-journeys.ts"
    },
    "keywords": [
        "travel",
        "ai",
        "rag",
        "saas",
        "fastify"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@anthropic-ai/sdk": "^0.96.0",
        "@fastify/cors": "^11.2.0",
        "fastify": "^5.6.1",
        "openai": "^6.38.0",
        "pdf-parse": "^2.4.5",
        "pg": "^8.20.0",
        "uuid": "^13.0.0",
        "zod": "^4.1.12"
    },
    "devDependencies": {
        "@types/node": "^24.10.1",
        "@types/pg": "^8.20.0",
        "tsx": "^4.20.6",
        "typescript": "^5.9.3",
        "vitest": "^4.0.8"
    }
}
